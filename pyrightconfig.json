{
  "typeCheckingMode": "strict",
  "include": ["./python"],
  "exclude": [
    "**/node_modules",
    "**/.venv",
    "**/__pycache__",
    "**/build",
    "**/dist"
  ],
  "extraPaths": ["./python"],
  "reportUnknownParameterType": "none",
  "reportUnknownArgumentType": "none",
  "reportUnknownVariableType": "none",
  "reportUnknownMemberType": "none",
  "reportUnusedVariable": "none",
  "reportAny": "warning",
  "diagnosticSeverityOverrides": {
    "reportUnknownMemberType": "none",
    "reportAny": "none"
  }
}
