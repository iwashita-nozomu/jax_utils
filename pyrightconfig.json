{
  "extends": "./pyproject.toml",
  "typeCheckingMode": "strict",
  "include": ["./python/jax_util"],
  "exclude": [
    "**/.*",
    "**/node_modules",
    "**/__pycache__",
    "**/build",
    "**/dist",
    "**/reports",
    "**/experiments",
    "**/*.egg-info",
    "./references",
    "./notes",
    "./diary",
    "./includes",
    "./lib",
    "./src",
    "./scripts",
    "./.worktrees",
    "./python/tests"
  ],
  "reportUnknownMemberType": "none",
  "reportUnknownVariableType": "none",
  "reportUnknownArgumentType": "none",
  "reportUnknownParameterType": "none"
}
